//@version=5
// ─────────────────────────────────────────────────────────────────────────
// GSP — Robust #2: Mean-Reversion (RSI(2)-Dip, Long-only)
//   >>> AUF DEM TAGESCHART (1D) NUTZEN <<<  (Indizes/ETFs: US500, US100, SPX…)
//
// Im Aufwärtstrend kurzfristige Rücksetzer kaufen (Connors-RSI(2)-Stil).
// Nur Long über der 200er-MA, Einstieg bei RSI(2) < 10, Ausstieg über der 5er-MA
// / Regimebruch / Zeit-Stop, ATR-Schutzstop. Größe = % des Kapitals (sicher).
// Hohe Trefferquote, aber Crash-Drawdown beachten. Messlatte: "Buy & hold return"
// schlagen (nach Kosten). Keine Garantie.
// ─────────────────────────────────────────────────────────────────────────
strategy("GSP — Mean-Reversion (Long-only)", overlay=true, initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100, pyramiding=0,
     calc_on_every_tick=false, commission_type=strategy.commission.percent,
     commission_value=0.0, slippage=0)

regimeLen = input.int(200, "Regime-MA (nur Long darüber)", minval=20)
rsiLen    = input.int(2,  "RSI-Länge", minval=1)
buyTh     = input.float(10, "RSI Kauf-Schwelle (Einstieg <)", minval=1)
exitMA    = input.int(5,  "Exit-MA (Schluss darüber)", minval=2)
atrLen    = input.int(14, "ATR-Länge", minval=2)
atrMult   = input.float(2.5, "ATR-Schutzstop-Faktor", minval=0.5, step=0.1)
maxBars   = input.int(10, "Max. Haltedauer (Bars)", minval=1)

sma  = ta.sma(close, regimeLen)
rsi  = ta.rsi(close, rsiLen)
maEx = ta.sma(close, exitMA)
atr  = ta.atr(atrLen)
bull = close > sma

longEntry = bull and rsi < buyTh and not na(atr) and strategy.position_size == 0

var float entryStop = na
var int   entryBar  = na
if longEntry
    strategy.entry("Long", strategy.long) // Größe = default_qty (100 % des Kapitals)
    entryStop := close - atrMult * atr
    entryBar := bar_index

if strategy.position_size > 0
    if not na(entryStop)
        strategy.exit("protect", "Long", stop=entryStop) // ATR-Schutzstop
    timeUp = not na(entryBar) and (bar_index - entryBar) >= maxBars
    if close > maEx or not bull or timeUp
        strategy.close("Long", comment="MR-Exit")
else
    entryStop := na
    entryBar := na

plot(sma, "Regime-MA (200)", color=color.new(color.gray, 0))
bgcolor(bull ? color.new(color.green, 94) : color.new(color.red, 94), title="Regime")
