# ── Frontend (Vite) ───────────────────────────────────────────
# These are PUBLIC values baked into the client bundle.
# NEVER put Capital.com credentials or API keys here — those live
# only in server/.env on the backend.

# Base URL of the backend proxy (server/index.mjs). Leave EMPTY for
# the public GitHub Pages demo: the app then runs in PUBLIC mode
# (XAU/USD spot + PAXG 4H proxy candles), clearly labelled, with no
# broker connection and no order buttons.
VITE_API_BASE_URL=

# Force public/demo mode even if a backend would be reachable.
# "true" hides all broker/account/order UI. Default: unset (auto).
VITE_PUBLIC_MODE=
