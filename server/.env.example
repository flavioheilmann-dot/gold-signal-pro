# Capital.com Proxy – Konfiguration
# Kopiere diese Datei zu  server/.env  und trage deine Werte ein.
# server/.env wird NICHT committet (siehe .gitignore). Niemals teilen!

# "live" = echtes Konto, "demo" = Demo-Konto
CAPITAL_ENV=live

# Aus Capital.com → Einstellungen → API-Integrationen:
CAPITAL_API_KEY=dein_api_key
CAPITAL_IDENTIFIER=deine_login_email
CAPITAL_API_PASSWORD=dein_api_passwort

# Order-Platzierung. EMPFEHLUNG: erst "false" (nur lesen) testen.
# Erst auf "true" setzen, wenn du Orders wirklich (manuell bestätigt) senden willst.
CAPITAL_TRADING_ENABLED=false

# Gold-Instrument bei Capital.com (Standard "GOLD")
GOLD_EPIC=GOLD

PORT=8787
